APP_ENV=development
APP_NAME=OpportunityOS
DATABASE_URL=postgresql+psycopg://opportunityos:opportunityos@localhost:5432/opportunityos
LLM_MODE=mock
ORCHESTRATOR=local

# Live mode accepts either provider or both. Keep LLM_MODE=mock until keys are configured.
LLM_PRIMARY_PROVIDER=auto
LLM_FALLBACK_ENABLED=true
LLM_MAX_CALLS_PER_ANALYSIS=5
LLM_MAX_ESTIMATED_INPUT_TOKENS_PER_ANALYSIS=18000
LLM_MAX_OUTPUT_TOKENS_PER_ANALYSIS=6000
LLM_MAX_PROMPT_CHARS=60000
LLM_MAX_SOURCE_CHARS=30000
LLM_EXTRACTION_MAX_OUTPUT_TOKENS=1200
LLM_ANALYSIS_MAX_OUTPUT_TOKENS=1600
LLM_OUTREACH_MAX_OUTPUT_TOKENS=900

OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

HTTP_TIMEOUT_SECONDS=30
MAX_SOURCE_BYTES=1000000
AUTO_CREATE_SCHEMA=true
