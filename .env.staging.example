COMPOSE_PROJECT_NAME=opportunityos_staging

APP_NAME=OpportunityOS-Staging
STAGING_PORT=8000

POSTGRES_DB=opportunityos
POSTGRES_USER=opportunityos
POSTGRES_PASSWORD=replace_with_a_long_hex_secret

LLM_MODE=mock
ORCHESTRATOR=local
LLM_PRIMARY_PROVIDER=auto
LLM_FALLBACK_ENABLED=true
LLM_MAX_CALLS_PER_ANALYSIS=5
LLM_MAX_ESTIMATED_INPUT_TOKENS_PER_ANALYSIS=18000
LLM_MAX_OUTPUT_TOKENS_PER_ANALYSIS=6000
LLM_MAX_PROMPT_CHARS=60000
LLM_MAX_SOURCE_CHARS=30000
LLM_EXTRACTION_MAX_OUTPUT_TOKENS=1200
LLM_ANALYSIS_MAX_OUTPUT_TOKENS=1600
LLM_OUTREACH_MAX_OUTPUT_TOKENS=900

OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

HTTP_TIMEOUT_SECONDS=30
MAX_SOURCE_BYTES=1000000
RUN_MIGRATIONS=true
DATABASE_WAIT_ATTEMPTS=30
DATABASE_WAIT_SECONDS=2
WEB_CONCURRENCY=1
FORWARDED_ALLOW_IPS=127.0.0.1
